    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT cs.nombre_curso, cs.precio_unitario \nFROM catalogo_servicios cs\nWHERE cs.id IN ({{ $json.servicio_id }});",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        416,
        -416
      ],
      "id": "633d0d8a-1de5-4e4b-b843-62174043eea7",
      "name": "B-Query para precio de los cursos",
      "credentials": {
        "postgres": {
          "id": "7u0PMl4oyQAqiWMF",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// 1. Inicializar variables de cálculo\nlet subtotalOriginal = 0;\nlet listaCursosTexto = \"\";\nconst ivaPorcentaje = 0.16;\n\n// 2. Capturar el descuento desde el Webhook (usando .first() para seguridad)\n// Si no viene descuento, se asume 0\nconst factorDescuento = parseFloat($('Webhook').first().json.body.descuento) || 0;\nconst porcentajeVisible = (factorDescuento * 100).toFixed(0) + \"%\";\n\n// 3. Procesar cada curso\nfor (const item of items) {\n  const nombre = item.json.nombre_curso || \"Curso sin nombre\";\n  const precio = parseFloat(item.json.precio_unitario) || 0;\n\n  subtotalOriginal += precio;\n  listaCursosTexto += `- ${nombre}: $${precio.toLocaleString('es-MX', {minimumFractionDigits: 2})}\\n`;\n}\n\n// 4. Cálculos con Descuento e IVA\nconst montoDescuento = subtotalOriginal * factorDescuento;\nconst subtotalConDescuento = subtotalOriginal - montoDescuento;\nconst iva = subtotalConDescuento * ivaPorcentaje;\nconst granTotal = subtotalConDescuento + iva;\n\n// 5. Fecha para el encabezado\nconst fechaHoy = new Date().toLocaleDateString('es-MX', {\n  day: '2-digit',\n  month: '2-digit',\n  year: 'numeric'\n});\n\n// 6. Redactar el cuerpo del borrador_ia incluyendo la nueva sección de descuentos\nconst borradorIA = `--- COTIZACIÓN GENERADA EL ${fechaHoy} ---\\n\\n` +\n                 `CURSOS ASIGNADOS:\\n` +\n                 `${listaCursosTexto}\\n` +\n                 `SUBTOTAL BASE: $${subtotalOriginal.toLocaleString('es-MX', {minimumFractionDigits: 2})}\\n` +\n                 `DESCUENTO (${porcentajeVisible}): -$${montoDescuento.toLocaleString('es-MX', {minimumFractionDigits: 2})}\\n` +\n                 `SUBTOTAL NETO: $${subtotalConDescuento.toLocaleString('es-MX', {minimumFractionDigits: 2})}\\n` +\n                 `IVA (16%): $${iva.toLocaleString('es-MX', {minimumFractionDigits: 2})}\\n` +\n                 `===========================\\n` +\n                 `TOTAL FINAL: $${granTotal.toLocaleString('es-MX', {minimumFractionDigits: 2})}`;\n\n// 7. Devolver el objeto consolidado\nreturn [{\n  json: {\n    total_cotizacion: granTotal.toFixed(2),\n    borrador_ia: borradorIA,\n    subtotal_base: subtotalOriginal.toFixed(2),\n    porcentaje_descuento: porcentajeVisible,\n    monto_descuento: montoDescuento.toFixed(2),\n    subtotal_neto: subtotalConDescuento.toFixed(2),\n    iva: iva.toFixed(2),\n    cantidad_cursos: items.length,\n    fecha_generacion: fechaHoy\n  }\n}];"
      },

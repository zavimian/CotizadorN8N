    {
      "parameters": {
        "jsCode": "// 1. Inicializar variables de cálculo\nlet subtotal = 0;\nlet listaCursosTexto = \"\";\nconst ivaPorcentaje = 0.16;\n\n// 2. Procesar cada curso que llega del nodo anterior\nfor (const item of items) {\n  // Intentamos obtener el nombre y precio. \n  // Si vienen de un SELECT de catalogo_servicios, se llaman nombre_curso y precio_unitario.\n  const nombre = item.json.nombre_curso || \"Curso sin nombre\";\n  const precio = parseFloat(item.json.precio_unitario) || 0;\n\n  subtotal += precio;\n  \n  // Formateamos cada línea para el borrador\n  listaCursosTexto += `- ${nombre}: $${precio.toLocaleString('es-MX', {minimumFractionDigits: 2})}\\n`;\n}\n\n// 3. Realizar cálculos finales (Sin descuento por ahora)\nconst iva = subtotal * ivaPorcentaje;\nconst granTotal = subtotal + iva;\n\n// 4. Obtener fecha actual para el encabezado\nconst fechaHoy = new Date().toLocaleDateString('es-MX', {\n  day: '2-digit',\n  month: '2-digit',\n  year: 'numeric'\n});\n\n// 5. Redactar el cuerpo del borrador_ia\nconst borradorIA = `--- COTIZACIÓN GENERADA EL ${fechaHoy} ---\\n\\n` +\n                 `CURSOS ASIGNADOS:\\n` +\n                 `${listaCursosTexto}\\n` +\n                 `SUBTOTAL: $${subtotal.toLocaleString('es-MX', {minimumFractionDigits: 2})}\\n` +\n                 `IVA (16%): $${iva.toLocaleString('es-MX', {minimumFractionDigits: 2})}\\n` +\n                 `===========================\\n` +\n                 `TOTAL FINAL: $${granTotal.toLocaleString('es-MX', {minimumFractionDigits: 2})}`;\n\n// 6. Devolver el objeto consolidado para los siguientes nodos (Update y PDF)\nreturn [{\n  json: {\n    total_cotizacion: granTotal.toFixed(2),\n    borrador_ia: borradorIA,\n    subtotal: subtotal.toFixed(2),\n    iva: iva.toFixed(2),\n    cantidad_cursos: items.length,\n    fecha_generacion: fechaHoy\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [

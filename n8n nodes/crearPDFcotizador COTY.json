    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT cs.nombre_curso, cs.precio_unitario \nFROM catalogo_servicios cs\nWHERE cs.id IN ({{ $json.servicio_id }});",
        "options": {}

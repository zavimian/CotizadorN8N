      "id": "9e248a5a-736a-4c78-9cf8-f142335a1a36",
      "name": "Query para precio de los cursos",
      "credentials": {
        "postgres": {
          "id": "7u0PMl4oyQAqiWMF",
          "name": "Postgres account"
        }
